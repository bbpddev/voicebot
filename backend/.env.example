# =============================================================
#  VoiceBot Backend — Environment Variables
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
# =============================================================

# --- API Keys (at least one is required for voice) ---
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- MongoDB ---
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=voicebot

# --- Admin Account (created on first startup) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_NAME=Admin

# --- Security ---
JWT_SECRET_KEY=change-me-use-a-long-random-string

# --- CORS (comma-separated, leave blank for defaults) ---
# Defaults: https://realtimevoicebot.netlify.app, https://voicebot.aigenstudio.online
ALLOWED_ORIGINS=
